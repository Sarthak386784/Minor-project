<%- include('partials/header') %>

<h1>Edit Transaction</h1>

<form action="/transactions/<%= txn.id %>?_method=PUT" method="POST" class="txn-form">
  <label for="senderUPI">Sender UPI ID</label>
  <input type="text" id="senderUPI" name="senderUPI" value="<%= txn.senderUPI %>" required />

  <label for="receiverUPI">Receiver UPI ID</label>
  <input type="text" id="receiverUPI" name="receiverUPI" value="<%= txn.receiverUPI %>" required />

  <label for="amount">Amount (₹)</label>
  <input type="number" id="amount" name="amount" min="1" step="0.01" value="<%= txn.amount %>" required />

  <label for="date">Date &amp; Time</label>
  <input type="datetime-local" id="date" name="date" value="<%= new Date(txn.date).toISOString().slice(0,16) %>" />

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Update Transaction</button>
    <a href="/transactions/<%= txn.id %>" class="btn">Cancel</a>
  </div>
</form>

<p class="hint">💡 Fraud status will be re-evaluated automatically when you update this transaction.</p>

<%- include('partials/footer') %>
