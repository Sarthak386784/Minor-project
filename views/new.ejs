<%- include('partials/header') %>

<h1>New Transaction</h1>

<form action="/transactions" method="POST" class="txn-form">
  <label for="senderUPI">Sender UPI ID</label>
  <input type="text" id="senderUPI" name="senderUPI" placeholder="e.g. rahul@okhdfc" required />

  <label for="receiverUPI">Receiver UPI ID</label>
  <input type="text" id="receiverUPI" name="receiverUPI" placeholder="e.g. shop@ybl" required />

  <label for="amount">Amount (₹)</label>
  <input type="number" id="amount" name="amount" min="1" step="0.01" placeholder="e.g. 5000" required />

  <label for="date">Date &amp; Time</label>
  <input type="datetime-local" id="date" name="date" />

  <div class="form-actions">
    <button type="submit" class="btn btn-primary">Save Transaction</button>
    <a href="/transactions" class="btn">Cancel</a>
  </div>
</form>

<p class="hint">💡 The system will automatically run fraud detection rules (amount threshold, blacklist, frequency, self-transfer) once you submit.</p>

<%- include('partials/footer') %>
